import java.util.Scanner;

public class Uppgift_7 {
	public static void main(String[]args) {

		Scanner input = new Scanner(System.in);
		System.out.println(" Välj alternativ för din ålder: "
				+ " 1 för x < 30, "
				+ " 2 för 30 ≤ x < 40, "
				+ " 3 för 40 ≤ age < 65, "
				+ " 4 för x ≥ 65, och "
				+ " 5 för en liten överaskning ");
		
		int alder = input.nextInt();
				
		switch(alder){
		case 1:
			System.out.println(" Ung ");
			break;
		case 2:
			System.out.println(" Medelålder ");
			break;
		case 3:
			System.out.println(" Övre medelålder ");
			break;
		case 4:
			System.out.println(" Gammal ");
			break;
		case 5:
			System.out.println(" Tillhör antikvariat ");
			break; 
		}
	}
}
