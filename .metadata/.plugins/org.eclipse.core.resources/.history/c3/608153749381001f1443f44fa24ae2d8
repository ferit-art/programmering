import java.util.Scanner;

public class Uppgift_4 {
	public static void main(String[] args) {
		Scanner input = new Scanner(System.in);
		System.out.println(" Mata in två heltal dork!: ");

		int tal_1 = input.nextInt();
		int tal_2 = input.nextInt();

		if ( tal_1 > tal_2) {

			System.out.println(" Det första talet är störst dork! ");

		} else if ( tal_1 == tal_2) {

			System.out.println(" Talen är lika stora dork! ");

		} else {
			
			System.out.println(" Det andra talet är störst dork! ");
		}

	}
}
