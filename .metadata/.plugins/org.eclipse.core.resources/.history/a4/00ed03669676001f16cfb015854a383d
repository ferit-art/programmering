		int tal_1 = 0;
		int tal_2 = 0;
		
		System.out.print(" Mata in två heltal: ");
		
		if (tal_2 <= 0) {
			System.out.println(" Mata in andra talet igen");
			tal_2 = input.nextInt();
		}
		
		try{
			tal_1 = input.nextInt();
			tal_2 = input.nextInt();
			
		}catch(Exception ime){
			System.out.println("Fel inmatning, försök igen");
		}
		int kvoten = tal_1 / tal_2 ;
		System.out.println("Kvoten = " + kvoten);
	}
}
