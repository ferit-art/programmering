package uppgift_5;
import java.awt.*;
import javax.swing.JFrame;

public class SquareTest extends JFrame {
    private static final long serialVersionUID = 1L;
	private Square s1, s2;
   
    public SquareTest() {
       s1 = new Square(20, 30, 40, Color.red);
       s2 = new Square(120, 130, 120, Color.blue);
      
       setSize(1000, 1000);
       setVisible(true);
       setDefaultCloseOperation(EXIT_ON_CLOSE);
      
       test();
    }
   
    public void test(){         	
       s1.setPos(200, 50);
       s2.setSide(80);
       repaint();
    }
   
    public void paint(Graphics g){
       s1.draw(g);
       s2.draw(g);
    }

    public static void main(String[] args) {
       new SquareTest();
    }
}

